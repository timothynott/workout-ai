# Neon Postgres — your personal dev branch connection string
# Run: neonctl connection-string dev/yourname --project-id <id> --pooled
DATABASE_URL=

# Neon Auth (BetterAuth) — from the Neon console Auth tab
NEON_AUTH_URL=
NEON_AUTH_SECRET=

# AI provider — set the matching API key for whichever provider you use
AI_PROVIDER=anthropic
AI_MODEL=claude-sonnet-4-6
AI_API_KEY=

# Comma-separated list of email addresses allowed to sign in
ALLOWED_EMAILS=you@example.com
