# Neon Postgres — your personal dev branch connection string (non-pooled, sslmode=verify-full)
# Run: neonctl connection-string dev/yourname --project-id <id>
# Note: use sslmode=verify-full (not require) so the pg driver used by db:migrate works correctly
DATABASE_URL=

# BetterAuth — session signing secret
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth — from Google Cloud Console → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Resend — email delivery for auth verification emails
# Get your API key at resend.com → API Keys
RESEND_API_KEY=
# Sending address — use onboarding@resend.dev for dev/testing (no domain setup needed)
# Switch to a verified domain address before going to production
RESEND_FROM_ADDRESS=onboarding@resend.dev

# Comma-separated list of email addresses allowed to sign in
ALLOWED_EMAILS=you@example.com

# Encryption key for sensitive fields (e.g. AI API keys stored in the database)
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=
